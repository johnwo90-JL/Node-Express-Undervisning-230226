# Miljøvariabler
# Miljø: Utvikling

NODE_ENV="development"

## JWT
JWT_SECRET="SomeSuperSecretValue!"
JWT_ACCESS_TOKEN_EXPIRY="3h"
JWT_REFRESH_TOKEN_EXPIRY="3d"

## DB

### Postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=node_express_db
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_DIALECT=postgres

### Sqlite3
DB_DIALECT="sqlite"
DB_STORAGE="./src/store/db.sqlite"


### Cookies
COOKIE_SECRET="SomeSuperSecretKey!"

